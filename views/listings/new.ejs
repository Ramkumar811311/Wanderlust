<style>
    /* CATEGORY GRID */
    .category-wrapper {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
        gap: 12px;
    }

    /* CATEGORY CARD */
    .category-item {
        border: 1px solid #ddd;
        border-radius: 12px;
        padding: 10px;
        text-align: center;
        cursor: pointer;
        transition: 0.25s;
        background: #fff;
    }

    .category-item i {
        font-size: 18px;
        margin-bottom: 5px;
    }

    .category-item p {
        font-size: 12px;
        margin: 0;
    }

    /* HOVER */
    .category-item:hover {
        border-color: #ff385c;
        transform: translateY(-2px);
    }

    .category-item.active {
        border: 2px solid #ff385c;
        background: #ffecef;
        color: #ff385c;
        transform: scale(1.08);
        box-shadow: 0 4px 12px rgba(255, 56, 92, 0.3);
        position: relative;
    }

    /* ✔ Tick mark */
    .category-item.active::after {
        content: "✔";
        position: absolute;
        top: 5px;
        right: 8px;
        font-size: 12px;
        color: #ff385c;
        font-weight: bold;
    }
</style>

<% layout("/layouts/boilerplate") %>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">

                <!-- Card -->
                <div class="card shadow-lg border-0 rounded-4 p-4">

                    <h3 class="text-center fw-bold mb-4">➕ Create New Listing</h3>

                    <form method="post" action="/listings" novalidate class="needs-validation"
                        enctype="multipart/form-data">

                        <!-- Title -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Title</label>
                            <input name="listing[title]" placeholder="Enter title" type="text"
                                class="form-control form-control-lg rounded-3 shadow-sm" required>
                            <div class="valid-feedback">Looks good!</div>
                            <div class="invalid-feedback">Please enter title</div>
                        </div>

                        <!-- Description -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="listing[description]" class="form-control rounded-3 shadow-sm" rows="4"
                                placeholder="Write something about your place..." required></textarea>
                            <div class="invalid-feedback">Enter description</div>
                        </div>

                        <!-- Upload Image -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Upload Listing Image</label>
                            <input name="listing[image]" type="file" class="form-control rounded-3 shadow-sm"
                                accept="image/*" required>
                        </div>

                        <!-- Price + Country -->
                        <div class="row">
                            <div class="col-md-4 mb-4">
                                <label class="form-label fw-semibold">Price ₹</label>
                                <input name="listing[price]" placeholder="₹" type="number" min="1"
                                    class="form-control rounded-3 shadow-sm" required>
                                <div class="invalid-feedback">Enter valid price</div>
                            </div>

                            <div class="col-md-8 mb-4">
                                <label class="form-label fw-semibold">Country</label>
                                <input name="listing[country]" placeholder="Enter country" type="text"
                                    class="form-control rounded-3 shadow-sm" required>
                                <div class="invalid-feedback">Enter country</div>
                            </div>
                        </div>

                        <!-- Location -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Location</label>
                            <input name="listing[location]" placeholder="Enter location" type="text"
                                class="form-control rounded-3 shadow-sm" required>
                            <div class="invalid-feedback">Enter location</div>
                        </div>

                        <!-- CATEGORY -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Select Category</label>

                            <div class="category-wrapper">

                                <input type="hidden" name="listing[category]" id="categoryInput" required>

                                <div class="category-item" data-value="trending">
                                    <i class="fa-solid fa-fire"></i>
                                    <p>Trending</p>
                                </div>

                                <div class="category-item" data-value="rooms">
                                    <i class="fa-solid fa-bed"></i>
                                    <p>Rooms</p>
                                </div>

                                <div class="category-item" data-value="mountain">
                                    <i class="fa-solid fa-mountain"></i>
                                    <p>Mountain</p>
                                </div>

                                <div class="category-item" data-value="beach">
                                    <i class="fa-solid fa-water"></i>
                                    <p>Beach</p>
                                </div>

                                <div class="category-item" data-value="camping">
                                    <i class="fa-solid fa-campground"></i>
                                    <p>Camping</p>
                                </div>

                                <div class="category-item" data-value="arctic">
                                    <i class="fa-solid fa-snowflake"></i>
                                    <p>Arctic</p>
                                </div>

                                <div class="category-item" data-value="forest">
                                    <i class="fa-solid fa-tree"></i>
                                    <p>Forest</p>
                                </div>

                                <div class="category-item" data-value="city">
                                    <i class="fa-solid fa-city"></i>
                                    <p>City</p>
                                </div>

                                <div class="category-item" data-value="lake">
                                    <i class="fa-solid fa-water-ladder"></i>
                                    <p>Lake</p>
                                </div>

                                <div class="category-item" data-value="trekking">
                                    <i class="fa-solid fa-person-hiking"></i>
                                    <p>Trekking</p>
                                </div>

                                <div class="category-item" data-value="cabins">
                                    <i class="fa-solid fa-warehouse"></i>
                                    <p>Cabins</p>
                                </div>

                            </div>

                            <div class="invalid-feedback">Please select a category</div>
                        </div>

                        <!-- Button -->
                        <div class="d-grid mt-3">
                            <button class="btn btn-danger btn-lg rounded-3 shadow">
                                🚀 Add Listing
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>

    <!-- Bootstrap Validation Script -->
    <script>
        document.querySelectorAll(".category-item").forEach(item => {

            item.addEventListener("click", () => {

                document.querySelectorAll(".category-item")
                    .forEach(i => i.classList.remove("active"));

                item.classList.add("active");

                let value = item.dataset.value;

                document.getElementById("categoryInput").value = value;

                // 🔥 update text
                document.getElementById("selectedText").innerText =
                    "Selected: " + item.innerText;

            });

        });
    </script>