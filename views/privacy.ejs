<% layout("/layouts/boilerplate") %>

    <style>
        body {
            background-color: #f7f7f7;
            font-family: 'Segoe UI', sans-serif;
        }

        .policy-container {
            max-width: 900px;
            margin: 40px auto;
            background: #fff;
            padding: 30px 40px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        .policy-container h1 {
            font-weight: 700;
            margin-bottom: 10px;
        }

        .policy-container p {
            color: #555;
        }

        .section {
            margin-top: 25px;
        }

        .section h4 {
            font-weight: 600;
            margin-bottom: 10px;
        }

        ul {
            padding-left: 20px;
        }

        .footer-links {
            text-align: center;
            margin-top: 30px;
        }

        .footer-links a {
            text-decoration: none;
            color: #ff385c;
            margin: 0 10px;
            font-weight: 500;
        }
    </style>

    <div class="policy-container">
        <h1>Privacy Policy</h1>
        <p><strong>Last updated:</strong>
            <%= new Date().toDateString() %>
        </p>

        <div class="section">
            <h4>1. Information We Collect</h4>
            <ul>
                <li>Name, email, and password during signup</li>
                <li>Listing details (title, price, location, images)</li>
                <li>Usage data like pages visited</li>
            </ul>
        </div>

        <div class="section">
            <h4>2. How We Use Information</h4>
            <ul>
                <li>To manage your account</li>
                <li>To display and manage listings</li>
                <li>To improve user experience</li>
            </ul>
        </div>

        <div class="section">
            <h4>3. Data Sharing</h4>
            <p>We do NOT sell your personal data. We only share data if required by law.</p>
        </div>

        <div class="section">
            <h4>4. Cookies</h4>
            <p>We use cookies to keep you logged in and improve performance.</p>
        </div>

        <div class="section">
            <h4>5. Data Security</h4>
            <p>Your data is protected using secure authentication and encryption.</p>
        </div>

        <div class="section">
            <h4>6. Your Rights</h4>
            <p>You can update or delete your account anytime.</p>
        </div>

        <div class="section">
            <h4>9. Contact</h4>
            <p>
                Email:
                <a href="mailto:ramkumar070406@gmail.com" class="email-link">
                    ramkumar070406@gmail.com
                </a>
            </p>
        </div>

        <div class="footer-links">
            <a href="/listings">Home</a>
            <a href="/terms">Terms</a>
        </div>
    </div>